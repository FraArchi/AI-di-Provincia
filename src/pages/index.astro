---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation';
import Footer from '../components/Footer.astro';
import { getRubriche } from '../lib/utils';
import { getCollection } from 'astro:content';
import { marked } from 'marked';

const rubriche = await getRubriche();
const posts = await getCollection('posts');

const sortedPosts = posts.sort((a, b) => new Date(b.data.published_date).valueOf() - new Date(a.data.published_date).valueOf());

const featuredArticle = sortedPosts.find(a => a.data.featured && !a.data.featuredOrder) || sortedPosts.find(a => a.data.featured);
const otherArticles = sortedPosts.filter(a => a.id !== featuredArticle?.id);

const sidebarFeaturedPosts = sortedPosts
  .filter(a => a.data.featured)
  .sort((a, b) => (a.data.featuredOrder || 99) - (b.data.featuredOrder || 99));

const formatDate = (dateString: string | Date) => {
  const date = new Date(dateString);
  return date.toLocaleDateString('it-IT', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};

const getExcerpt = (body: string) => {
  const parts = body.split('\n\n').slice(0, 3).join('\n\n');
  return marked.parse(parts);
};
---

<Layout title="AI di Provincia">
  <Navigation client:load currentPage="home" rubriche={rubriche} />
  
  <main class="flex-grow">
    <div class="bg-white">
      <div class="max-w-6xl mx-auto px-6 py-16">
        <div class="mb-16 pb-8 border-b border-gray-200">
          <h1 class="text-5xl font-serif font-bold text-gray-900 mb-3">
            AI di Provincia
          </h1>
          <p class="text-xl text-gray-600">
            L'intelligenza artificiale vista da chi vive lontano dai centri tecnologici
          </p>
        </div>

        {featuredArticle && (
          <article class="mb-20">
            {featuredArticle.data.category && (
              <span class="text-sm font-medium text-accent uppercase tracking-wide mb-4 block">
                {featuredArticle.data.category}
              </span>
            )}
            <h2 class="text-5xl font-serif font-bold text-gray-900 mb-4 leading-tight">
              {featuredArticle.data.title}
            </h2>
            {featuredArticle.data.subtitle && (
              <p class="text-2xl text-gray-600 mb-8 leading-relaxed">
                {featuredArticle.data.subtitle}
              </p>
            )}
            <div class="flex gap-4 text-sm text-gray-500 mb-8 pb-8 border-b border-gray-200">
              <span class="font-medium">{featuredArticle.data.author}</span>
              <span>&middot;</span>
              <span>{formatDate(featuredArticle.data.published_date)}</span>
            </div>

            <div class="excerpt-content max-w-none mb-8 text-gray-800 leading-relaxed text-lg" set:html={getExcerpt(featuredArticle.body || '')}></div>

            <a
              href={`/post/${featuredArticle.data.slug || featuredArticle.id}`}
              class="inline-block text-accent font-medium hover:underline transition-colors"
            >
              Leggi l'articolo completo &rarr;
            </a>
          </article>
        )}

        {otherArticles.length > 0 && (
          <div class="grid md:grid-cols-3 gap-12 border-t border-gray-200 pt-12">
            
            {/* Feed Centrale (Articoli Principali) - 2/3 width */}
            <div class="md:col-span-2">
              <h3 class="text-xl font-bold font-serif text-gray-900 mb-8 border-b pb-2">Articoli Recenti</h3>
              <div class="grid sm:grid-cols-2 gap-8">
                {otherArticles.filter(a => a.data.category !== "Il Bollettino dell'IA").map((article) => (
                  <article class="group">
                    <a
                      href={`/post/${article.data.slug || article.id}`}
                      class="text-left w-full block"
                    >
                      {article.data.category && (
                        <span class="text-xs font-medium text-accent uppercase tracking-wide mb-2 block">
                          {article.data.category}
                        </span>
                      )}
                      <h4 class="text-xl font-serif font-bold text-gray-900 mb-2 group-hover:text-accent transition-colors leading-snug">
                        {article.data.title}
                      </h4>
                      {article.data.subtitle && (
                        <p class="text-sm text-gray-600 mb-3 line-clamp-2">
                          {article.data.subtitle}
                        </p>
                      )}
                      <div class="flex gap-2 text-xs text-gray-500">
                        <span>{article.data.author}</span>
                        <span>&middot;</span>
                        <span>{formatDate(article.data.published_date)}</span>
                      </div>
                    </a>
                  </article>
                ))}
              </div>
            </div>

            {/* Sidebar Laterale (I preferiti) - 1/3 width */}
            <div class="md:col-span-1 bg-gray-50 p-6 rounded-xl border border-gray-100">
              <h3 class="text-lg font-bold font-serif text-gray-900 mb-6 flex items-center gap-2">
                <span class="text-accent">★</span> I preferiti
              </h3>
              <div class="space-y-6">
                {sidebarFeaturedPosts.map((article) => (
                  <article class="border-b border-gray-200 pb-6 last:border-0 last:pb-0">
                     <a
                      href={`/post/${article.data.slug || article.id}`}
                      class="text-left w-full group block"
                    >
                      {article.data.category && (
                        <span class="text-xs font-medium text-accent uppercase tracking-wide mb-2 block">
                          {article.data.category}
                        </span>
                      )}
                      <h4 class="text-base font-bold text-gray-900 mb-1 group-hover:text-accent transition-colors leading-tight">
                        {article.data.title}
                      </h4>
                      {article.data.subtitle && (
                        <p class="text-xs text-gray-600 mt-1 line-clamp-2">
                          {article.data.subtitle}
                        </p>
                      )}
                    </a>
                  </article>
                ))}
                
                {sidebarFeaturedPosts.length === 0 && (
                  <p class="text-sm text-gray-500 italic">Nessun articolo preferito.</p>
                )}
              </div>
            </div>

          </div>
        )}
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
